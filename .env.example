# ── Base de datos ─────────────────────────────────────────────
# Formato: mysql+aiomysql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=mysql+aiomysql://root:TU_PASSWORD@localhost:3306/umedic_db

# ── JWT ───────────────────────────────────────────────────────
# Cambia esto por una cadena aleatoria larga (mínimo 32 caracteres)
SECRET_KEY=cambia_esto_por_una_clave_secreta_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── SMTP (opcional) ───────────────────────────────────────────
# Si se deja vacío, el código de verificación aparece en la consola del servidor
# Para Gmail: activar "Contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@umedic.local

# ── Google Drive (opcional) ───────────────────────────────────
# 1. Crear cuenta de servicio en Google Cloud Console
# 2. Habilitar la API de Google Drive
# 3. Descargar el JSON de credenciales → guardarlo en credentials/drive_credentials.json
# 4. Compartir la carpeta de Drive con el email de la cuenta de servicio
GOOGLE_CREDENTIALS_FILE=credentials/drive_credentials.json
GOOGLE_DRIVE_FOLDER_ID=
